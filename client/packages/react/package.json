{
  "name": "gepa-viz",
  "version": "0.1.0",
  "description": "React components for visualizing GEPA prompt-optimization runs.",
  "author": "Tyrin Todd <tyrin@modaic.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modaic-ai/gepa-viz.git",
    "directory": "client/packages/react"
  },
  "homepage": "https://github.com/modaic-ai/gepa-viz#readme",
  "keywords": [
    "gepa",
    "dspy",
    "prompt-optimization",
    "visualization",
    "react"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/gepa-viz.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && npm run build:css",
    "build:css": "tailwindcss -i src/styles.css -o dist/gepa-viz.css --minify",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-zoom": "^3.0.0",
    "diff": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-zoom": "^3.0.8",
    "@types/diff": "^7.0.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "bumpp": "^10.4.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1"
  }
}
